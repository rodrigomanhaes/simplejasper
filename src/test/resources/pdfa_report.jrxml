<jasperReport name="pdfa_report" language="java" pageWidth="595" pageHeight="842"
    columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
  <style name="Base" default="true" fontName="DejaVu Sans Condensed"/>
  <parameter name="title" class="java.lang.String"/>
  <field name="name" class="java.lang.String"><description>name</description></field>
  <field name="value" class="java.lang.String"><description>value</description></field>
  <detail>
    <band height="40">
      <element kind="textField" x="0" y="0" width="500" height="20">
        <expression><![CDATA[$F{name} + " = " + $F{value}]]></expression>
      </element>
    </band>
  </detail>
</jasperReport>
